// Focused, runnable schema for the Compliance Intelligence app (the models the UI actually
// uses). The comprehensive enterprise design lives in schema.architecture.prisma.reference
// and ARCHITECTURE.md. Semantic string IDs (DE-TA-LUFT, CHG-2038, ACT-881, site refs) are
// used as primary keys to match the rest of the app.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  ref      String  @id
  name     String
  country  String
  cc       String
  jur      String
  type     String
  role     String
  line     String
  emp      Int?
  score    Int
  risk     String
  open     Int
  permits  Int
}

model Regulation {
  id        String   @id
  title     String
  jur       String
  topic     String
  agency    String
  status    String
  eff       String
  risk      String
  comp      String
  owner     String
  sites     String[]
  watch     Boolean  @default(false)
  changed   String
  createdAt DateTime @default(now())

  @@index([jur])
  @@index([topic])
  @@index([status])
}

model ChangeEvent {
  id          String   @id
  regId       String
  title       String
  jur         String
  topic       String
  sev         String
  cat         String
  impact      String
  status      String
  eff         String
  sites       String[]
  line        String
  owner       String
  date        String
  conf        String
  prevVersion String?
  currVersion String?
  prevText    String?
  currText    String?
  createdAt   DateTime @default(now())

  @@index([regId])
  @@index([sev])
  @@index([status])
}

model ActionItem {
  id        String   @id
  title     String
  reg       String
  chg       String
  site      String
  line      String
  pri       String
  owner     String
  due       String
  status    String
  ev        String
  createdAt DateTime @default(now())

  @@index([site])
  @@index([status])
}

model AppUser {
  id        String   @id
  name      String
  email     String   @unique
  title     String
  role      String
  scopeType String
  scope     String[]
  status    String
  createdAt String
}

// cache of generated AI impact analyses, keyed by changeId or a text hash
model ImpactCache {
  key       String   @id
  payload   Json
  createdAt DateTime @default(now())
}
