# Copy to .env and adjust. Defaults match docker-compose.yml.
DATABASE_URL="postgresql://ci:ci@localhost:5432/compliance?schema=public"
REDIS_URL="redis://localhost:6379"
ORG_ID="waygate"

# Data backend: "memory" (default, no DB) or "prisma" (Postgres durability).
# For prisma: docker compose up -d  →  npm run db:setup  →  set DATA_BACKEND=prisma
DATA_BACKEND="memory"

# Cloudflare Access — application-specific identity verification.
# Set both to verify the Access JWT and bind it to THIS app's audience tag.
#   CF_ACCESS_TEAM_DOMAIN = https://<your-team>.cloudflareaccess.com
#   CF_ACCESS_AUD         = the Application Audience (AUD) tag from the Access app's Overview
# CF_ACCESS_TEAM_DOMAIN=""
# CF_ACCESS_AUD=""
# Local dev without Access — act as a given user:
# DEV_USER_EMAIL="tony.hammond@bakerhughes.com"

# Provider selection — all default to MOCK so the app runs with no external services.
REGULATORY_FEED_PROVIDER="mock"   # mock | enhesa
AI_PROVIDER="mock"                # mock | anthropic
EMAIL_PROVIDER="mock"             # mock | resend | sendgrid
STORAGE_PROVIDER="mock"           # mock | s3 | azure
IDP="mock"                        # mock | oidc | saml

# Fill these only when switching a provider off "mock":
# ANTHROPIC_API_KEY=
# RESEND_API_KEY=
# AWS_S3_BUCKET=
